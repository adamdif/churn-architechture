# =====================================================================
#  MODÈLE de variables d'environnement — À COPIER en `.env`
#  (`cp .env.example .env` puis remplir). Le `.env` réel est dans
#  .gitignore : on ne committe JAMAIS de credential.
# =====================================================================

# --- Kaggle (https://www.kaggle.com -> Account -> Create New API Token) ---
KAGGLE_USERNAME=votre_pseudo_kaggle
KAGGLE_KEY=votre_cle_kaggle

# --- Projet ---
# Bucket racine : généralement votre nom d'utilisateur sur le SSP Cloud.
S3_BUCKET=churn-project
# Facteur d'amplification (100 ≈ 700 k lignes, 1000 ≈ 7 M lignes).
AMPLIFY_FACTOR=100
